# AI-Vaani — Environment Variables
# Copy this file to .env and fill in your API keys
# Load with: source .env  OR use python-dotenv

# ── Required ────────────────────────────────────────────────────────────────

# Groq Cloud API key (free at https://console.groq.com)
# Used for: Llama-3-70B inference (500+ tok/sec)
GROQ_API_KEY=your_groq_api_key_here

# ── Choose ONE STT provider ──────────────────────────────────────────────────

# Option A: Speechmatics (recommended — 8 free hours/month, best Marathi support)
# Sign up at: https://www.speechmatics.com/
SPEECHMATICS_API_KEY=your_speechmatics_api_key_here

# Option B: Google Cloud STT (60 minutes free/month)
# Create a service account at: https://console.cloud.google.com
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service_account.json

# ── Optional ────────────────────────────────────────────────────────────────

# Streamlit config (for deployment)
# STREAMLIT_SERVER_PORT=8501
# STREAMLIT_SERVER_ADDRESS=0.0.0.0
